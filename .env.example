# YOLOMODE Gateway Environment
# Copy to .env and fill in values. This file is gitignored.

# Bitbucket API token for git operations
# Create at: https://id.atlassian.com/manage-profile/security/api-tokens
BITBUCKET_YOLOMODE_TOKEN=
BITBUCKET_USERNAME=

# Telegram notifications for escalations
# Bot: @taxlatesdatabot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_THREAD_ID=
